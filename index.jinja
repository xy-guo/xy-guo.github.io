<!DOCTYPE HTML>
<html lang="en">

<head>
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">

  <title>Xiaoyang Guo</title>

  <meta name="author" content="Xiaoyang Guo">
  <meta name="description" content="Xiaoyang Guo — research on embodied foundation models, 3D reconstruction, Gaussian Splatting, and VGGT.">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="shortcut icon" href="images/favicon/favicon.ico" type="image/x-icon">
  <link rel="stylesheet" type="text/css" href="stylesheet.css">

</head>

<body>
  <table
    style="width:100%;max-width:850px;border:0px;border-spacing:0px;border-collapse:separate;margin-right:auto;margin-left:auto;">
    <tbody>
      <tr style="padding:0px;">
        <td style="padding:0px;">
          <!-- profile -->
          <table
            style="width:100%;border:0px;border-spacing:0px;border-collapse:separate;margin-right:auto;margin-left:auto;">
            <tbody>
              <tr style="padding:0px">
                <td style="padding:2.5%;width:63%;vertical-align:middle;">
                  <p class="name" style="text-align: center;">
                    Xiaoyang Guo (郭晓阳)
                  </p>
                  <p>
                    I work on embodied foundation models that unify understanding, simulation, and action.
                    Previously, I was a Principal Researcher at Horizon Robotics, where I led work on
                    3D reconstruction, digital twins, and interactive driving simulation.
                    I received my Ph.D. from <a href="http://mmlab.ie.cuhk.edu.hk/">the Multimedia Laboratory (MMLab)</a> at <a
                      href="http://www.cuhk.edu.hk/english/index.html">The Chinese University of Hong Kong</a>,
                    where I was fortunate to be advised by <a href="https://www.ee.cuhk.edu.hk/~xgwang/">Prof. Xiaogang Wang</a> and <a
                      href="https://www.ee.cuhk.edu.hk/~hsli/">Prof. Hongsheng Li</a>.
                    Prior to that, I obtained my Bachelor's degree in Computer Science from <a
                      href="https://www.tsinghua.edu.cn/">Tsinghua University</a>.
                  </p>
                  <p>
                    My research interests include large-scale 3D scene understanding (multi-view reconstruction, Gaussian Splatting, and VGGT),
                    high-precision 3D reconstruction and digital twins for autonomous driving,
                    and embodied foundation models.
                  </p>
                  <p>
                    I am actively seeking highly motivated interns to collaborate on projects involving
                    embodied foundation models, 3D foundation models, and generative simulation. If you're interested, feel free to reach out via email.
                  </p>
                  <p style="text-align:center">
                    <a href="mailto:xiaoyang.guo1995@gmail.com">Email</a> &nbsp;/&nbsp;
                    <a href="/files/cv.pdf">CV</a> &nbsp;/&nbsp;
                    <a href="https://scholar.google.com/citations?hl=en&user=CrK4w4UAAAAJ">Scholar</a> &nbsp;/&nbsp;
                    <a href="https://github.com/xy-guo">Github</a>
                  </p>
                </td>
                <td style="padding:2.5%;width:30%;max-width:30%">
                  <a href="/images/portrait/xiaoyang.jpg">
                    <img style="width:100%;max-width:100%;object-fit: cover; border-radius: 50%;" alt="profile photo"
                      src="/images/portrait/xiaoyang.jpg?v=20260711c" class="hoverZoomLink"></a>
                </td>
              </tr>
            </tbody>
          </table>

          <!-- news -->
          <table
            style="width:100%;border:0px;border-spacing:0px;border-collapse:separate;margin-right:auto;margin-left:auto;">
            <tbody>
              <tr>
                <td style="padding:2.5%;padding-top:0;padding-bottom:0;">
                  <h2>News</h2>
                </td>
              </tr>
              <tr>
                <td style="padding:2.5%;padding-top:8px;">
                  <ul style="margin:0;padding-left:18px;">
                    {% for item in news %}
                    <li style="margin-bottom:4px;"><strong>{{ item.date }}</strong>: {{ item.text }}</li>
                    {% endfor %}
                  </ul>
                </td>
              </tr>
            </tbody>
          </table>

          <!-- papers -->
          <table
            style="width:100%;border:0px;border-spacing:0px;border-collapse:separate;margin-right:auto;margin-left:auto;">
            <tbody>
              <tr>
                <td style="padding:2.5%;padding-bottom:0;" colspan="2">
                  <h2>Selected Publications</h2>
                  <p style="margin:6px 0 0 0;color:#666;font-size:13px;">
                    <strong>*</strong> equal contribution; <strong>†</strong> project lead.
                    Full list on <a href="https://scholar.google.com/citations?hl=en&user=CrK4w4UAAAAJ&view_op=list_works&sortby=pubdate">Google Scholar</a>.
                  </p>
                </td>
              </tr>
              {% for paper in papers %}
              <!-- {{paper.conference}}, {{paper.year}} - {{paper.title}} -->
              <tr style="padding: 20px; margin: 10px; min-height: 100px" {% if paper.yellow_highlight %}
                bgcolor="#ffffd0" {% endif %}>
                <td onmouseout="{{paper.tag}}_stop()" onmouseover="{{paper.tag}}_start()" style="padding:5px;height:150px; width:25%;vertical-align:middle;">
                  <div class="one" style="display: flex; align-items: center; justify-content: center; height: 100%;">
                    <div class="two" id="{{paper.tag}}_hover">
                      {% if paper.image_after is not none %}
                      <img src='{{paper.image_after}}' width=100%>
                      {% elif paper.video_after is not none %}
                      <video width=100% height=100% muted autoplay loop>
                        <source src="{{paper.video_after}}" type="video/mp4">
                        Your browser does not support the video tag.
                      </video>
                      {% endif %}
                    </div>
                    <div id="{{paper.tag}}_default">
                      <img src='{{paper.image}}' width=100%>
                    </div>
                  </div>

                  <script type="text/javascript">
                    function {{ paper.tag }}_start() {
                      document.getElementById('{{paper.tag}}_hover').style.opacity = "1";
                      document.getElementById('{{paper.tag}}_default').style.opacity = "0";
                    }

                    function {{ paper.tag }}_stop() {
                      document.getElementById('{{paper.tag}}_hover').style.opacity = "0";
                      document.getElementById('{{paper.tag}}_default').style.opacity = "1";
                    }
                    {{ paper.tag }}_stop()
                  </script>
                </td>
                <td style="padding:10px;width:75%;vertical-align:middle;">
                  <div>
                  <a href="{{paper.url}}">
                    <span class="papertitle">{{paper.title}}
                    </span>
                  </a>
                  <br>
                  {% for author in paper.authors %}
                  {% if not author.name.startswith(name) %}
                  {% if author.url is not none %}
                  <a href="{{author.url}}">{{author.name}}</a>{% if not loop.last %}, {% endif %}
                  {% else %}
                  {{author.name}}{% if not loop.last %}, {% endif %}
                  {% endif %}
                  {% else %}
                  <strong>{{author.name}}</strong>{% if not loop.last %}, {% endif %}
                  {% endif %}
                  {% endfor %}
                  <br>
                  <em>{{paper.conference}}, <strong>{{paper.conference_short}}</strong></em> &nbsp
                  {% if paper.special_honor is not none %}
                  <font color="red"><strong>({{paper.special_honor}})</strong></font>
                  {% endif %}
                  <br>

                  {% if paper.url_arxiv is not none %}
                  <a href="{{ paper.url_arxiv }}">[arXiv]</a>
                  {% endif %}

                  {% if paper.url_project_page is not none %}
                  <a href="{{ paper.url_project_page }}">[project page]</a>
                  {% endif %}

                  {% if paper.url_paper is not none %}
                  <a href="{{ paper.url_paper }}">[paper]</a>
                  {% endif %}

                  {% if paper.url_supp is not none %}
                  <a href="{{ paper.url_supp }}">[supp]</a>
                  {% endif %}

                  {% if paper.url_video is not none %}
                  <a href="{{ paper.url_video }}">[video]</a>
                  {% endif %}

                  {% if paper.url_poster is not none %}
                  <a href="{{ paper.url_poster }}">[poster]</a>
                  {% endif %}

                  {% if paper.url_code is not none %}
                  <a href="{{ paper.url_code }}">[code]</a>
                  {% endif %}

                  {% if paper.url_dataset is not none %}
                  <a href="{{ paper.url_dataset }}">[dataset]</a>
                  {% endif %}

                  {% if paper.description is not none %}
                  <p><font color="gray">{{paper.description}}</font></p>
                  {% endif %}
                  </div>
                </td>
              </tr>
              {% endfor %}

            </tbody>
          </table>

          <!-- footer -->
          <table
            style="width:100%;border:0px;border-spacing:0px;border-collapse:separate;margin-right:auto;margin-left:auto;">
            <tbody>
              <tr>
                <td style="padding:0px">
                  <br>
                  <p style="text-align:right;font-size:small;">
                    Thanks for the template from <a href="https://github.com/jonbarron/jonbarron_website">Jon Barron
                    </a>.
                  </p>
                </td>
              </tr>
            </tbody>
          </table>
        </td>
      </tr>
  </table>
</body>

</html>
